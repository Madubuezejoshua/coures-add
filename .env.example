# Copy to .env and fill in. Only DATABASE_URL + JWT_SECRET are required to run.

# --- Required ---
# Neon / Postgres connection string
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Secret used to sign JWTs (use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# --- API server (optional) ---
PORT=5050
# HOST=127.0.0.1
# CORS_ORIGIN=http://localhost:5173

# --- Frontend (optional) ---
# In dev the Vite proxy targets the API; only set this for production:
# VITE_API_URL=https://your-api.example.com/api
# VITE_API_TARGET=http://127.0.0.1:5050   # dev proxy target override

# --- Optional integrations (left as placeholders = safely mocked) ---
# Cloudflare R2 / S3 (file uploads)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# Paystack (payments)
PAYSTACK_SECRET_KEY=sk_test_xxx
# SendGrid (email)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=no-reply@your-app.example.com
